      "postcss": ">=8.5.10",
      "next-intl": "4.13.1",
      "@tanstack/react-query": "5.101.2"
    }
  },
  "trustedDependencies": [
    "@clerk/shared",
    "@parcel/watcher",
    "@swc/core",
    "unrs-resolver"
